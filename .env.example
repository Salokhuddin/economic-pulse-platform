# =============================================================================
# Economic Pulse Platform — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   copy .env.example .env
#
# NEVER commit .env to Git — it contains secrets.
# =============================================================================

# --- Django ---
DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_SECRET_KEY=change-me-to-a-random-string-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database (PostgreSQL) ---
POSTGRES_DB=epp_dev
POSTGRES_USER=epp_user
POSTGRES_PASSWORD=epp_secret
POSTGRES_HOST=localhost
POSTGRES_PORT=5434

# --- API Keys (add as needed in future sprints) ---
# FRED_API_KEY=your-fred-api-key-here
# BLS_API_KEY=your-bls-api-key-here
# GNEWS_API_KEY=your-gnews-api-key-here
# CENSUS_API_KEY=your-census-api-key-here
